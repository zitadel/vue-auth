    "start": "vite",
    "test": "playwright test",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@zitadel/vue-auth": "file:..",
    "oidc-client-ts": "^3.4.0",
    "vue": "^3.5.0",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@playwright/test": "^1.48.0",
    "@types/node": "^24",
    "@vitejs/plugin-vue": "^6.0.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^9.32.0",
    "globals": "^16.3.0",
    "prettier": "^3.6.2",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.20.0",
    "vite": "^7.3.2",
    "vue-tsc": "^2.2.0"
  }
}
