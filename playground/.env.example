# -----------------------------------------------------------------------------
# App Configuration
# -----------------------------------------------------------------------------
# The environment in which the application is running. For local development,
# 'development' is appropriate.
NODE_ENV=development

# The network port on which the Vite dev server will listen for incoming
# connections. Change this if port 3000 is already in use on your system.
PORT=3000

# -----------------------------------------------------------------------------
# ZITADEL OpenID Connect (OIDC) Configuration
# -----------------------------------------------------------------------------
# This is a browser-only Single Page Application using the Authorization Code
# Flow with PKCE. There is NO client secret and NO server session: every value
# below is shipped to the browser and is safe to expose. Vite only exposes
# variables prefixed with VITE_ to client code.

# The full domain URL of your ZITADEL instance. You can find this in your
# ZITADEL organization's settings.
# Example: https://my-org-a1b2c3.zitadel.cloud
VITE_ZITADEL_DOMAIN="https://your-zitadel-domain"

# The unique Client ID for your application, obtained from the ZITADEL Console.
# The application must be a "User Agent" / SPA client using PKCE.
VITE_ZITADEL_CLIENT_ID="your-zitadel-application-client-id"

# The full URL where ZITADEL redirects the user after they have authenticated.
# This MUST exactly match one of the "Redirect URIs" configured in your
# ZITADEL application settings.
VITE_ZITADEL_CALLBACK_URL="http://localhost:3000/auth/callback"

# The full URL where ZITADEL redirects the user after they have logged out.
# This MUST exactly match one of the "Post Logout Redirect URIs" configured
# in your ZITADEL application settings.
VITE_ZITADEL_POST_LOGOUT_URL="http://localhost:3000/auth/logout/callback"
